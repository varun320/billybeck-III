# GA4 MCP (googleanalytics/google-analytics-mcp via uvx analytics-mcp)
# Absolute path to a service account JSON key, OR an ADC credentials JSON.
# Service account (recommended): create in GCP Console → IAM → Service Accounts → Keys → Add key (JSON)
# ADC alternative:
#   gcloud auth application-default login \
#     --scopes https://www.googleapis.com/auth/analytics.readonly,https://www.googleapis.com/auth/cloud-platform
GOOGLE_APPLICATION_CREDENTIALS=

# GCP project with Google Analytics Admin API + Google Analytics Data API enabled.
GOOGLE_PROJECT_ID=

# GSC MCP (AminForou/mcp-gsc via uvx mcp-search-console)
# Same service account key file works for both GA4 and GSC — just point to it again.
# The SA must be added as a user in the GSC property (search.google.com/search-console).
GSC_CREDENTIALS_PATH=

# WordPress MCP (staging) — wpmcp plugin HTTP/streamable endpoint on the site.
# Full URL to the plugin route, e.g. https://<host>/wp-json/wp/v2/wpmcp/streamable
WP_MCP_URL=

# JWT bearer for the wpmcp endpoint. Generated in wp-admin (wpmcp plugin settings).
# Tokens expire — check exp claim, rotate before expiry, never commit.
WP_MCP_JWT=

# Elementor MCP (elementor-mcp via npx) — uses WP REST API + Application Password.
# Base site URL, no trailing slash, no /wp-json path.
WP_ELEMENTOR_URL=
# WP user with edit_posts capability (usually admin email or login).
WP_ELEMENTOR_USER=
# Application Password (wp-admin → Users → Profile → Application Passwords).
# Keep the spaces-or-no-spaces form the UI gives you; never commit.
WP_ELEMENTOR_APP_PASSWORD=
